RDGEN_PORT=8001

# Django
SECRET_KEY=replace_with_long_random_value

# GitHub repo that runs generator workflows
GHUSER=your_github_username
GHBEARER=your_github_fine_grained_token
REPONAME=rdgen
GHBRANCH=master

# Public URL of this rdgen instance
GENURL=https://rdgen.example.com
PROTOCOL=https

# Must match repository Actions secret ZIP_PASSWORD
ZIP_PASSWORD=replace_with_long_random_value
